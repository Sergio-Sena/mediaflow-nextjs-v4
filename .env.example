# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# S3 Buckets
NEXT_PUBLIC_S3_UPLOADS_BUCKET=mediaflow-uploads-ACCOUNT_ID
NEXT_PUBLIC_S3_PROCESSED_BUCKET=mediaflow-processed-ACCOUNT_ID

# CloudFront
NEXT_PUBLIC_CLOUDFRONT_DOMAIN=your_cloudfront_domain.cloudfront.net

# API Gateway
NEXT_PUBLIC_API_URL=https://your_api_id.execute-api.us-east-1.amazonaws.com/prod
